{
  "id": "true-chromatic",
  "name": "True Chromatic",
  "version": "0.1.0",
  "api_version": 1,
  "component_type": "input_mode",
  "description": "Non-overlapping chromatic pad layout with scale filtering and root note selection.",
  "author": "Schwung",
  "capabilities": {
    "input_mode": true,
    "pad_led_modes": ["pass_through", "module"]
  },
  "input_mode": {
    "engine": "host_static",
    "mode": "true_chromatic_poc"
  },
  "params": [
    {
      "key": "root",
      "name": "Root",
      "label": "Root",
      "type": "note",
      "default": 48,
      "min": 36,
      "max": 72
    },
    {
      "key": "scale",
      "name": "Scale",
      "label": "Scale",
      "type": "enum",
      "default": "chromatic",
      "options": ["Chromatic","Major","Minor","Dorian","Phrygian","Lydian","Mixolydian","Locrian","Harmonic Minor","Melodic Minor","Major Pentatonic","Minor Pentatonic","Blues"],
      "values": ["chromatic","major","minor","dorian","phrygian","lydian","mixolydian","locrian","harmonic_minor","melodic_minor","major_pentatonic","minor_pentatonic","blues"]
    }
  ]
}
